<div class="box" id="spinning-box"></div>

<script>
	import { onPageLifecycle } from "../../../utils/viewTransitionLifecycle";

	onPageLifecycle(() => {
		const box = document.getElementById("spinning-box");
		if (!box) return;

		const observer = new IntersectionObserver(
			([entry]) => {
				if (entry.isIntersecting) {
					box.classList.add("animate");
				} else {
					box.classList.remove("animate");
				}
			},
			{ threshold: 0.2, rootMargin: "-30% 0px" },
		);

		observer.observe(box);
		return () => observer.disconnect();
	});
</script>

<style>
	.box {
		width: 100px;
		height: 100px;
		margin: 2em;
		border-radius: 4px;
		background: #2d2a55;
		transform: translateX(0) rotate(0deg);
		transition: transform 0.8s ease-out;
		will-change: transform;
	}

	.box.animate {
		transform: translateX(20vw) rotate(360deg);
	}
</style>
