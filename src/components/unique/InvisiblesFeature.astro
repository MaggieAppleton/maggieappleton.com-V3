---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

const { illustrator, imageURL, sourceURL, sourceTitle } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>("/src/images/**/*");

let resolved: ImageMetadata | null = null;
if (typeof imageURL === "string" && imageURL.startsWith("/images")) {
	const loader = images["/src" + imageURL];
	if (typeof loader === "function") {
		resolved = (await loader()).default;
	}
}
---

<div class="invisibles-feature-container">
	<div>
		<h4>{illustrator}</h4>
		<a href={sourceURL}>
			<h4>{sourceTitle}</h4>
		</a>
		<p><slot /></p>
	</div>
	{
		resolved ? (
			<Picture
				src={resolved}
				alt={sourceTitle}
				formats={["avif", "webp", "jpg"]}
				widths={[500, 1000]}
				sizes="(max-width: 768px) 100vw, 500px"
				loading="lazy"
				decoding="async"
			/>
		) : (
			<img alt={sourceTitle} src={imageURL} loading="lazy" />
		)
	}
</div>

<style>
	.invisibles-feature-container {
		grid-column: 1/4;
		display: grid;
		grid-template-columns: repeat(2, minmax(220px, 1fr));
		grid-gap: var(--space-l);
		max-width: 1000px;
		margin: var(--space-m) auto var(--space-l);
		justify-content: center;
		font-family: var(--font-body);
	}

	@media (max-width: 768px) {
		.invisibles-feature-container {
			grid-template-columns: repeat(1, minmax(200px, 1fr));
			grid-gap: var(--space-xs);
		}
	}

	.invisibles-feature-container h4 {
		margin-top: 0;
	}

	.invisibles-feature-container :global(img) {
		border-radius: 5px;
		width: 100%;
		height: auto;
		align-self: start;
		object-fit: contain;
	}

	.invisibles-feature-container :global(picture) {
		align-self: start;
	}

	@media (max-width: 768px) {
		.invisibles-feature-container img {
			max-width: 100%;
			width: 500px;
			margin: inherit auto;
		}
	}

	.invisibles-feature-container p {
		margin-bottom: var(--space-xs);
	}
</style>
